        <mxCell id="n166" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF2E3;strokeColor=#D86613;fontColor=#D86613;fontSize=9;fontStyle=1;arcSize=8;dashed=0;align=left;verticalAlign=top;spacing=4;" value="RECOVERY OBJECTIVE (NOT RPO / RTO)  IRE is not for DR / HA. It is for Cyber Recovery. The objective is to restore critical services safely within an acceptable recovery window." vertex="1">
