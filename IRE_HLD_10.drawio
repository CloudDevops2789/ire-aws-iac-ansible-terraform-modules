        <mxCell id="n160" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#232F3E;fontColor=#FFFFFF;fontSize=10;fontStyle=1;arcSize=8;dashed=0;align=center;verticalAlign=middle;spacing=4;" value="IDENTITY &amp; ACCESS GOVERNANCE" vertex="1">
