        <mxCell id="n170" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5EDF8;strokeColor=#7D3AC1;fontColor=#7D3AC1;fontSize=9;fontStyle=1;arcSize=8;dashed=0;align=center;verticalAlign=middle;spacing=4;" value="&lt; 24 HOURS BETTER ✓ Faster restoration of critical capabilities" vertex="1">
